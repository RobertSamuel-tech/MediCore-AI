# ── OpenRouter — LLM backend for all agents ──────────────────────────────────

OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat


# ── Agent public URLs (defaults work for local dev) ───────────────────────────
# Set to your deployed / ngrok URLs when exposing agents publicly.

DIAGNOSIS_AGENT_URL=http://localhost:8001
INTAKE_AGENT_URL=http://localhost:8002
ORCHESTRATOR_URL=http://localhost:8003
CARE_NAVIGATOR_AGENT_URL=http://localhost:8004
TREATMENT_PLANNER_AGENT_URL=http://localhost:8005
INSURANCE_BILLING_AGENT_URL=http://localhost:8006
FOLLOWUP_ADHERENCE_AGENT_URL=http://localhost:8007
HEALTH_MEMORY_AGENT_URL=http://localhost:8008
SOCIAL_BARRIER_AGENT_URL=http://localhost:8009


# ── Medplum FHIR — longitudinal memory backend ───────────────────────────────
# Create a ClientApplication in your Medplum project to get these credentials.
# https://app.medplum.com/admin/clients

MEDPLUM_BASE_URL=https://api.medplum.com
MEDPLUM_CLIENT_ID=your-medplum-client-id
MEDPLUM_CLIENT_SECRET=your-medplum-client-secret


# ── Optional — A2A / internal API keys ───────────────────────────────────────

API_KEY_PRIMARY=my-secret-key-123
API_KEY_SECONDARY=another-valid-key
AGENT_API_KEY=medicore-dev-key


# ── Optional — FHIR context (per-session EHR credentials via A2A metadata) ───

FHIR_EXTENSION_URI=https://your-workspace.promptopinion.ai/schemas/a2a/v1/fhir-context


# ── Optional — logging ────────────────────────────────────────────────────────

LOG_LEVEL=info
